# App — remplacer par votre URL Vercel en production
NEXT_PUBLIC_APP_URL=https://votre-projet.vercel.app

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require"

# Auth.js — générer avec: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=https://votre-projet.vercel.app

# Paystack PRODUCTION — https://dashboard.paystack.com/#/settings/developers
# Utiliser sk_live_ et pk_live_ (pas sk_test_)
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxx
PAYSTACK_CURRENCY=NGN
PAYSTACK_USD_TO_NGN=1600

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Resend — domaine vérifié recommandé en production
RESEND_API_KEY=
RESEND_FROM_EMAIL=TemplateHub CM <noreply@votre-domaine.com>

COMMISSION_RATE=0.25
